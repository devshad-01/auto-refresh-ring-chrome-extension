{
  "manifest_version": 3,
  "name": "Auto Refresh Alert",
  "version": "1.1.0",
  "description": "Monitor web pages for target text and trigger persistent ring or notification alerts.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "notifications",
    "storage",
    "alarms",
    "scripting",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Auto Refresh Alert",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "homepage_url": "https://github.com/devshad-01/auto-refresh-ring-chrome-extension"
}
